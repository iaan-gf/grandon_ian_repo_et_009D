def leer_opcion():
    while True:
        opcion = input("igrese una opcion")
        if opcion == "":
            print("ERROR. La opcion no puede quedar vacia")
        elif opcion.strip() == " ":
            print("ERROR. la opcion no puede contener solo espacios")
        else
            try:
                opcion = int(opcion)
                if opcion not in (1,2,3,4,5,6):
                    print("ERROR. la opcio no es valida")
                else: 
                    return opcion
            except ValueError as e:
                print("ERRR. la opcion ingresada no es valida")
                print("detalle del error,", e)



