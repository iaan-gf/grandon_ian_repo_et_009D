def rengo_de_pecios():
    while True:
        precio_min = input("ingresa el precio")
        precio_max = input("ingresa el precio")
        if precio_min or precio_max == "":
            print("ERROR. La opcion no puede quedar vacia")
        elif precio_min.strip or precio_max.strip () == " ":
            print("ERROR. la opcion no puede contener solo espacios")
        else:
            try
                precio_min = float(precio_min)
                precio_max = float(precio_max)
                if precio_min < 0 or precio_max < 0:
                    print("ERROR. el precio no puede ser negativo")
                if precio_min > precio_max:
                    print("ERROR. precio minimonopuede ser mayor al maximo")
                    return precio_min, precio_max
            except ValueError as e:
                print("ERRR. la opcion ingresada no es valida")
                print("detalle del error,",e)


def rango_de_precio():
    precio_min, precio_max = rango_de_precio()
    plan_en_rango = []
    for plan, (precio, stock) in inscripciones.items():
        if(precio_min <= precio <= precio_max) and (stock > 0):
            plan_en_rango.append((plan,inscripciones[plan][0], precio,stock))
        if plan_en_rango:
            print(f"plandisponible {precio_min} - {precio_max}:")
            for plan, inscripciones, stock in plan_en_rango
            print(f"plan: {plan}, precio: {precio}, cupos: {stock}") 
        else
            print(f"no se encuentra {precio_min} - {precio_max}")

